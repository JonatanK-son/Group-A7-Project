    "for stage, elapsed in timings.items():\n",
    "    print(f'{stage:<25} {elapsed:>10.1f}')\n",
    "print('=' * 37)\n",
    "print(f'{\"TOTAL\":<25} {sum(timings.values()):>10.1f}')\n",
    "\n",
    "# ── Output files ──────────────────────────────────────────────────────────────\n",
    "print('\\n=== Output Files ===')\n",
